# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override Anthropic model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-opus-4-6

# Local llama.cpp server (provider: local)
LLAMA_BASE_URL=http://localhost:8080/v1
LLAMA_API_KEY=none
LLAMA_MODEL=qwen3.5-35b-a3b-q6
LLAMA_EMBED_URL=http://localhost:8081/v1
EMBED_MODEL=nomic-embed-text

# Ollama (provider: ollama) — uncomment to enable
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:32b

# OpenAI (provider: openai) — uncomment to enable
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# OpenRouter (provider: openrouter) — uncomment to enable
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# AWS Bedrock (provider: bedrock) — requires: uv pip install boto3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# BEDROCK_MODEL=anthropic.claude-sonnet-4-6-v1:0

# Per-agent-type provider overrides (override routing per agent class)
# ORCHID_ORCHESTRATOR_PROVIDER=claude
# ORCHID_REVIEWER_PROVIDER=claude
# ORCHID_DEVELOPER_PROVIDER=local
# ORCHID_RESEARCHER_PROVIDER=local

# Offline mode: route all agents to local provider
# ORCHID_OFFLINE_MODE=false

# Logging
ORCHID_LOG_LEVEL=INFO
ORCHID_LOG_DIR=.orchid/session_logs

# Telegram bot (Milestone 2.4)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs to whitelist (leave blank to allow all — dev mode only)
TELEGRAM_ALLOWED_USERS=

# Slack bot (Milestone 3.2)
# Create app at https://api.slack.com/apps — enable Socket Mode
# Bot Token (xoxb-) from OAuth & Permissions
SLACK_BOT_TOKEN=
# App-Level Token (xapp-) from Basic Information > App-Level Tokens (scope: connections:write)
SLACK_APP_TOKEN=
# Default channel for notifications (#channel-name or C0XXXXXXX channel ID)
SLACK_DEFAULT_CHANNEL=
