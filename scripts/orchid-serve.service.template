# orchid-serve.service.template
#
# systemd unit file for running the Orchid central bot service with Telegram and Slack support.
# Uses the --bots flag to enable both Telegram and Slack bot handlers in a single service.
#
# Usage:
#   1. Copy to /etc/systemd/system/orchid-serve.service
#   2. Edit User, WorkingDirectory, EnvironmentFile, and ExecStart as needed
#   3. systemctl daemon-reload
#   4. systemctl enable --now orchid-serve
#   5. journalctl -u orchid-serve -f   # to follow logs
#
# Environment Variables Required:
#   TELEGRAM_BOT_TOKEN  — Telegram bot token (required for Telegram bot)
#                         Get from @BotFather on Telegram
#   SLACK_BOT_TOKEN     — Slack bot token (required for Slack bot)
#                         Format: xoxb-...
#                         Get from Slack API app settings
#   SLACK_APP_TOKEN     — Slack app-level token (required for Slack Socket Mode)
#                         Format: xapp-...
#                         Enable Socket Mode in Slack app settings
#   ANTHROPIC_API_KEY   — Anthropic API key for Claude models (required)
#
# Optional Environment Variables:
#   ORCHID_LOG_LEVEL    — Log level (debug, info, warning, error). Default: info
#   ORCHID_PORT         — Web UI port. Default: 7842
#
# Slack App Prerequisites:
#   - Slack app created at https://api.slack.com/apps
#   - Socket Mode enabled in app settings
#   - Bot Token (xoxb-) added to .env as SLACK_BOT_TOKEN
#   - App-Level Token (xapp-, scope: connections:write) added as SLACK_APP_TOKEN
#   - Slash commands registered: /orchid-status, /orchid-run, /orchid-auto,
#     /orchid-add, /orchid-recall, /orchid-search, /orchid-inject, /orchid-help
#   - app_mentions:read event subscription enabled
#
# Telegram Bot Prerequisites:
#   - Bot created via @BotFather on Telegram
#   - Bot token added to .env as TELEGRAM_BOT_TOKEN
#   - Bot added to project channels/groups as needed
#
# Variables to replace:
#   {{USER}}         — system user that runs the service (e.g. dave)
#   {{ORCHID_DIR}}   — path to orchid installation (e.g. /home/dave/LocalAI/orchid)
#   {{PROJECT_DIR}}  — path to the project to work on (e.g. /home/dave/projects/myapp)
#   {{ENV_FILE}}     — path to .env file containing TELEGRAM_BOT_TOKEN, SLACK_BOT_TOKEN etc.

[Unit]
Description=Orchid Central Bot Service (Telegram + Slack) — {{PROJECT_DIR}}
After=network.target
Wants=network-online.target

[Service]
Type=simple
User={{USER}}
WorkingDirectory={{ORCHID_DIR}}
EnvironmentFile={{ENV_FILE}}

# Central bot service with --bots flag to enable both Telegram and Slack handlers
ExecStart={{ORCHID_DIR}}/.venv/bin/orchid serve \
    --project {{PROJECT_DIR}} \
    --bots \
    --port {{PORT:-7842}} \
    --log-level {{LOG_LEVEL:-info}}
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=orchid-serve

# Resource limits
MemoryMax=1G
CPUQuota=100%

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths={{PROJECT_DIR}}/.orchid

[Install]
WantedBy=multi-user.target